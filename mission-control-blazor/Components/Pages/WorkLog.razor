@page "/worklog"
@rendermode InteractiveServer
@inject WorkLogService WorkLogs

<PageTitle>Work Log · Mission Control</PageTitle>

@if (_days.Count == 0)
{
    <div class="page-grid">
        <section class="page-header panel">
            <div>
                <p class="eyebrow">Daily memory</p>
                <h2>Work log timeline</h2>
                <p class="muted">A browseable day-by-day log for Clare and Wilko's work history, read directly from durable workspace files.</p>
            </div>
        </section>

        <section class="panel state-panel">
            <div class="state-stack">
                <span class="live-dot"></span>
                <strong>No daily work log files found.</strong>
                <span class="muted compact">Expected folder: <code>@WorkLogs.MemoryDirectoryPath</code></span>
            </div>
        </section>
    </div>
}
else
{
    <div class="page-grid">
        <section class="page-header panel">
            <div>
                <p class="eyebrow">Daily memory</p>
                <h2>Work log timeline</h2>
                <p class="muted">Browse day-by-day summaries of Clare and Wilko's discussions and project history. Reads durable markdown files from the workspace memory folder.</p>
            </div>
            <div class="refresh-note">
                <span class="live-pill"><span class="live-dot"></span> Durable files</span>
                <span class="muted compact">@_days.Count day@(_days.Count == 1 ? "" : "s") available</span>
            </div>
        </section>

        <section class="stats-strip panel worklog-stats">
            <div class="stat-cell">
                <span class="stat-label">Days tracked</span>
                <strong class="stat-value">@_days.Count</strong>
                <span class="muted compact">Markdown files in memory/</span>
            </div>
            <div class="stat-cell">
                <span class="stat-label">Latest entry</span>
                <strong class="stat-value">@_days.First().Date.ToString("ddd dd MMM")</strong>
                <span class="muted compact">Newest durable summary</span>
            </div>
            <div class="stat-cell">
                <span class="stat-label">Selected day</span>
                <strong class="stat-value">@Selected.Date.ToString("dddd")</strong>
                <span class="muted compact">@Selected.Date.ToString("yyyy-MM-dd")</span>
            </div>
            <div class="stat-cell">
                <span class="stat-label">Sections</span>
                <strong class="stat-value">@Selected.Sections.Count</strong>
                <span class="muted compact">Parsed headings / notes</span>
            </div>
        </section>

        <section class="panel worklog-layout">
            <aside class="worklog-sidebar">
                <div class="worklog-sidebar-header">
                    <div>
                        <p class="eyebrow">Days</p>
                        <h3>History index</h3>
                    </div>
                    <span class="muted compact">@WorkLogs.MemoryDirectoryPath</span>
                </div>

                <div class="worklog-day-list">
                    @foreach (var day in _days)
                    {
                        <button type="button"
                                class="worklog-day @(day.Date == _selectedDate ? "active" : "")"
                                @onclick="() => Select(day.Date)">
                            <div>
                                <strong>@day.Date.ToString("ddd dd MMM")</strong>
                                <span class="muted compact">@day.Date.ToString("yyyy-MM-dd")</span>
                            </div>
                            <div class="worklog-day-meta">
                                <span>@day.Sections.Count section@(day.Sections.Count == 1 ? "" : "s")</span>
                            </div>
                        </button>
                    }
                </div>
            </aside>

            <article class="worklog-detail">
                <header class="worklog-detail-header">
                    <div>
                        <p class="eyebrow">Selected day</p>
                        <h3>@Selected.Date.ToString("dddd, dd MMMM yyyy")</h3>
                        <p class="muted">Practical summary view for reviewing what was learned, decided, or delivered that day.</p>
                    </div>
                    <div class="detail-tags">
                        <span class="badge-chip">Durable</span>
                        <span class="badge-chip">Workspace memory</span>
                    </div>
                </header>

                @if (Selected.Sections.Count == 0)
                {
                    <div class="panel subtle-panel">
                        <span class="muted">This file exists but did not parse into visible sections.</span>
                    </div>
                }
                else
                {
                    <div class="worklog-sections">
                        @foreach (var entry in Selected.Sections)
                        {
                            <section class="worklog-section panel">
                                @if (!string.IsNullOrWhiteSpace(entry.Heading))
                                {
                                    <div class="section-heading-row">
                                        <p class="eyebrow">Section</p>
                                        <h4>@entry.Heading</h4>
                                    </div>
                                }

                                @if (entry.BodyLines.Count > 0)
                                {
                                    @foreach (var line in entry.BodyLines)
                                    {
                                        <p class="worklog-paragraph">@((MarkupString)WorkLogService.InlineHtml(line))</p>
                                    }
                                }

                                @if (entry.Bullets.Count > 0)
                                {
                                    <ul class="worklog-bullets">
                                        @foreach (var bullet in entry.Bullets)
                                        {
                                            <li>@((MarkupString)WorkLogService.InlineHtml(bullet))</li>
                                        }
                                    </ul>
                                }
                            </section>
                        }
                    </div>
                }

                <details class="panel source-trace open-by-default" open>
                    <summary>
                        <span>Raw source</span>
                        <span class="muted compact">Verbatim durable file content</span>
                    </summary>
                    <pre class="worklog-raw"><code>@Selected.RawMarkdown</code></pre>
                </details>
            </article>
        </section>
    </div>
}

@code {
    private List<WorkLogDay> _days = [];
    private DateOnly? _selectedDate;

    private WorkLogDay Selected => _days.FirstOrDefault(d => d.Date == _selectedDate) ?? _days[0];

    protected override void OnInitialized()
    {
        _days = WorkLogs.GetAll();
        _selectedDate = _days.FirstOrDefault()?.Date;
    }

    private void Select(DateOnly date) => _selectedDate = date;
}
