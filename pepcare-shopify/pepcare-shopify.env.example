# Copy to pepcare-shopify.env and fill in the Admin API access token.
# IMPORTANT:
# - SHOPIFY_ACCESS_TOKEN must be the custom app Admin API token (usually starts with shpat_)
# - A value starting with shpss_ is the API secret key, NOT the Admin API token

SHOPIFY_SHOP_DOMAIN=pepcare-lab.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_REPLACE_ME
SHOPIFY_API_VERSION=2024-10
