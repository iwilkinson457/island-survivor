# Copy to pepcare-shopify.env and fill in the OAuth client credentials.
# The connector will mint an Admin API token via:
#   POST /admin/oauth/access_token
#   Content-Type: application/x-www-form-urlencoded
#   grant_type=client_credentials&client_id=...&client_secret=...

SHOPIFY_SHOP_DOMAIN=pepcare-lab.myshopify.com
SHOPIFY_CLIENT_ID=REPLACE_ME
SHOPIFY_CLIENT_SECRET=REPLACE_ME
SHOPIFY_API_VERSION=2024-10
